ts inception in early 2025, the program has yielded major community impacts:\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"className\\\":\\\"list-disc pl-6 space-y-2.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"Over \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"20,000+\\\"}],\\\" individual patient consultations.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"More than \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"100+\\\"}],\\\" diagnostic camps organized across 50 distinct slum clusters.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Successful detection and early treatment of anemia in over 2,500 children and pregnant women.\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Regular healthcare monitoring and free drug supplies provided for 800+ diabetic and hypertensive patients.\\\"}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"1f:[[\\\"$\\\",\\\"meta\\\",\\\"0\\\",{\\\"charSet\\\":\\\"utf-8\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"viewport\\\",\\\"content\\\":\\\"width=device-width, initial-scale=1\\\"}]]\\n\"])</script><script>self.__next_f.push([1,\"22:I[27201,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"IconMark\\\"]\\n1c:null\\n21:[[\\\"$\\\",\\\"title\\\",\\\"0\\\",{\\\"children\\\":\\\"Delhi Medical Checkup Initiative | Face of Change\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"description\\\",\\\"content\\\":\\\"Read the full story of our medical camps, health diagnostics, and essential medicine distribution in Delhi NCR's underserved slum communities.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"2\\\",{\\\"name\\\":\\\"keywords\\\",\\\"content\\\":\\\"NGO India,Face of Change,Rural Education India,Solar Power India,Healthcare Camps Delhi,Odisha Development\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"3\\\",{\\\"property\\\":\\\"og:title\\\",\\\"content\\\":\\\"Face of Change\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"4\\\",{\