3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5\",\"key\":\"mvr1a0\"}]],\"className\":\"lucide-heart w-3.5 h-3.5 text-forest fill-forest/15\"}],[\"$\",\"span\",null,{\"className\":\"text-[10px] uppercase tracking-widest font-semibold text-forest\",\"children\":\"Healthcare Program\"}]]}],[\"$\",\"h1\",null,{\"className\":\"font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-navy leading-tight max-w-4xl\",\"children\":\"Healing Slums: Delivering Diagnostic Care & Medicine Directly to Delhi's Marginalized\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-4 sm:gap-6 text-xs text-navy/50 font-medium border-y border-navy/5 py-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center space-x-2\",\"children\":[[\"$\",\"$L4\",null,{\"iconNode\":[[\"path\",{\"d\":\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\",\"key\":\"1r0f0z\"}],[\"circle\",{\"cx\":\"12\",\"cy\":\"10\",\"r\":\"3\",\"key\":\"ilqhr7\"}]],\"className\":\"lucide-map-pin w-4 h-4 text-forest\"}],[\"$\",\"span\",null,{\"children\":\"Delhi NCR Slums, India\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex items-center space-x-2\",\"children\":[[\"$\",\"$L4\",null,{\"iconNode\":[[\"path\",{\"d\":\"M8 2v4\",\"key\":\"1cmpym\"}],[\"path\",{\"d\":\"M16 2v4\",\"key\":\"4m81vk\"}],[\"rect\",{\"width\":\"18\",\"height\":\"18\",\"x\":\"3\",\"y\":\"4\",\"rx\":\"2\",\"key\":\"1hopcy\"}],[\"path\",{\"d\":\"M3 10h18\",\"key\":\"8toen8\"}]],\"className\":\"lucide-calendar w-4 h-4 text-forest\"}],[\"$\",\"span\",null,{\"children\":\"Launched Jan 2025\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex items-center space-x-2\",\"children\":[[\"$\",\"$L4\",null,{\"iconNode\":[[\"path\",{\"d\":\"M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z\",\"key\":\"vktsd0\"}],[\"circle\",{\"cx\":\"7.5\",\"cy\":\"7.5\",\"r\":\".5\",\"fill\":\"currentColor\",\"key\":\"kqv944\"}]],\"className\":\"lucide-tag w-4 h-4 text-forest\"}],[\"$\",\"span\",null,{\"children\":\"Diagnostics, Essential Medicine\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"relative aspect-[21/9] w-full rounded-3xl overflow-hidden border border-navy/5 shadow-sm\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/assets/project_delhi_medical.png\",\"alt\":\"Delhi Medical Camp Cover\",\"fill\":true,\"priority\":true,\"className\":\"object-cover\"}]}],[\"$\",\"div\",null,{\"className\":\"text-navy/80 font-sans text-sm sm:text-base leading-relaxed space-y-16\",\"children\":[[\"$\",\"div\",null,{\"className\":\"max-w-3xl space-y-6\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium text-navy text-base sm:text-lg leading-relaxed\",\"children\":\"In the heart of Delhi's bustling urban sprawl, hundreds of informal settlements (slums) house families living in severe congestion with minimal access to primary healthcare. For a daily wage laborer, missing a day of work to visit a crowded government hospital is an unaffordable luxury. As a result, treatable infections and chronic illnesses go unchecked until they reach critical stages.\"}],[\"$\",\"p\",null,{\"children\":[\"The \",[\"$\",\"strong\",null,{\"children\":\"Delhi Medical Checkup Initiative\"}],\" was launched by Face of Change to bridge this gap. Rather than asking patients to travel, we bring the hospital directly to their doorstep. By setting up temporary diagnostic camps in narrow alleys and community centers, we make premium medical consultations and diagnostics completely free and accessible.\"]}]]}],\"$L6\",\"$L7\",\"$L8\"]}],\"$L9\"]}]}],\"$La\"],[\"$Lb\",\"$Lc\"],\"$Ld\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"JNUvGBU4_yyeOPkxQuXyD\"}\n6:[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center\",\"children\":[[\"$\",\"div\",null,{\"className\":\"lg:col-span-7 space-y-6\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Every diagnostic camp is fully equipped with portable test kits, allowing for rapid testing of blood glucose, hemoglobin, and vital markers. In addition, experienced general physicians, pediatricians, and gynecologists volunteer their time to offer specialized attention to the residents.\"}],[\"$\",\"blockquote\",null,{\"className\":\"border-l-4 border-forest pl-6 py-2 bg-forest/5 rounded-r-2xl\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-serif italic text-sm sm:text-base text-navy leading-relaxed\",\"children\":\"\\\"Our mission is simple: eliminate the barrier of distance and cost. When healthcare comes to the community, prevention becomes possible.\\\"\"}],[\"$\",\"cite\",null,{\"className\":\"text-xs font-semibold text-navy/60 not-italic block mt-2\",\"children\":\"— Dr. A. Sharma, Program Lead\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"lg:col-span-5 space-y-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative aspect-[4/3] w-full rounded-2xl overflow-hidden border border-navy/5 shadow-sm\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/assets/delhi_medical_doctor.png\",\"alt\":\"Doctor checking child at Delhi camp\",\"fill\":true,\"className\":\"object-cover\"}]}],[\"$\",\"p\",null,{\"className\":\"text-[11px] text-center text-navy/40 italic\",\"children\":\"Volunteer doctor conducting health checkups for children.\"}]]}]]}]\n7:[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center\",\"children\":[[\"$\",\"div\",null,{\"className\":\"lg:col-span-5 space-y-2 order-last lg:order-first\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative aspect-[4/3] w-full rounded-2xl overflow-hidden border border-navy/5 shadow-sm\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/assets/delhi_medical_pharmacy.png\",\"alt\":\"Medicine distribution counter at Delhi camp\",\"fill\":true,\"className\":\"object-cover\"}]}],[\"$\",\"p\",null,{\"className\":\"text-[11px] text-center text-navy/40 italic\",\"children\":\"Our medicine counter offering free prescription drugs.\"}]]}],[\"$\",\"div\",null,{\"className\":\"lg:col-span-7 space-y-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-serif text-xl sm:text-2xl font-bold text-navy\",\"children\":\"Beyond Diagnostics: Providing the Cure\"}],[\"$\",\"p\",null,{\"children\":\"Diagnosing an illness is only the first step. Many families diagnosed with chronic conditions like hypertension or diabetes struggle to afford prescribed treatments. Recognizing this, our camps operate a fully stocked, mobile pharmacy. Patients walk out of their consultation directly to our distribution desk where they receive high-grade, essential medicines, vitamins, and supplements at zero cost.\"}],[\"$\",\"p\",null,{\"children\":\"Furthermore, we maintain electronic health records of patients with critical readings, ensuring that our team can follow up during subsequent visits. By partnering with local municipal clinics, patients requiring advanced secondary surgery or specialized therapy are smoothly referred and fast-tracked to the correct public care facilities.\"}]]}]]}]\n8:[\"$\",\"div\",null,{\"className\":\"max-w-3xl space-y-6 pt-4 border-t border-navy/5\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-serif text-xl sm:text-2xl font-bold text-navy\",\"children\":\"Measurable Outcomes\"}],[\"$\",\"p\",null,{\"children\":\"Since its inception in early 2025, the program has yielded major community impacts:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-6 space-y-2.5\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"Over \",[\"$\",\"strong\",null,{\"children\":\"20,000+\"}],\" individual patient consultations.\"]}],[\"$\",\"li\",null,{\"children\":[\"More than \",[\"$\",\"strong\",null,{\"children\":\"100+\"}],\" diagnostic camps organized across 50 distinct slum clusters.\"]}],[\"$\",\"li\",null,{\"children\":\"Successful detection and early treatment of anemia in over 2,500 children and pregnant women.\"}],[\"$\",\"li\",null,{\"children\":\"Regular healthcare monitoring and free drug supplies provided for 800+ diabetic and hypertensive patients.\"}]]}]]}]\n9:[\"$\",\"div\",null,{\"className\":\"bg-white border border-navy/5 rounded-3xl p-8 sm:p-12 space-y-6 shadow-sm text-center\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-serif text-2xl sm:text-3xl font-bold text-navy\",\"children\":\"Help Us Expand Our Medical Reach\"}],[\"$\",\"p\",null,{\"className\":\"text-navy/60 text-sm max-w-xl mx-auto leading-relaxed\",\"children\":\"Every diagnostic camp costs approximately ₹45,000 ($550) to run, providing complete checkups and medicine to over 200 residents. Partner with us to sponsor a clinic in an underserved area.\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-col sm:flex-row gap-4 justify-center pt-2\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/contact\",\"className\":\"inline-flex items-center justify-center px-8 py-3.5 rounded-full bg-navy text-white font-semibold text-sm transition-transform duration-300 hover:scale-105 shadow-md\",\"children\":\"Sponsor A Health Camp\"}],[\"$\",\"$L3\",null,{\"href\":\"/projects\",\"className\":\"inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-navy/20 bg-white text-navy font-semibold text-sm transition-transform duration-300 hover:scale-105 shadow-sm\",\"children\":[[\"$\",\"$L4\",null,{\"iconNode\":[[\"path\",{\"d\":\"m12 19-7-7 7-7\",\"key\":\"1l729n\"}],[\"path\",{\"d\":\"M19 12H5\",\"key\":\"x3x0zl\"}]],\"className\":\"lucide-arrow-left w-4 h-4 mr-2\"}],\"Back to Projects\"]}]]}]]}]\na:[\"$\",\"$Le\",null,{}]\nb:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/1b-psm4bewz71.js\",\"async\":true}]\nc:[\"$\",\"script\",\"script-1\",{\"src\":\"/_next/static/chunks/1m3vej2wqjff6.js\",\"async\":true}]\nd:[\"$\",\"$Lf\",null,{\"children\":[\"$\",\"$10\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":