{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/projects/layout,_N_T_/projects/delhi/layout,_N_T_/projects/delhi/page,_N_T_/projects/delhi"},"segmentPaths":["/_tree","/_full","/projects/delhi/__PAGE__","/projects/delhi","/projects","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"playfair_display_d5eda251-module__JGL7aG__variable inter_7b064e0d-module__MOT0tq__variable h-full antialiased scroll-smooth\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/2a65768255d6b625-s.p.3u4lli0-axodc.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/83afe278b6a6bb3c-s.p.2bn3s6zvc0dyp.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=3840&amp;q=75 3840w\" imageSizes=\"100vw\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/03lv3qopdqw50.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0iq1i69206cyl.js\"/><script src=\"/_next/static/chunks/10muk0s002m9w.js\" async=\"\"></script><script src=\"/_next/static/chunks/3peubv2924kx4.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-0-crjjlsgf_t5.js\" async=\"\"></script><script src=\"/_next/static/chunks/05-c3ty_6dwfk.js\" async=\"\"></script><script src=\"/_next/static/chunks/14mrh2-p_w84d.js\" async=\"\"></script><script src=\"/_next/static/chunks/1b-psm4bewz71.js\" async=\"\"></script><script src=\"/_next/static/chunks/1m3vej2wqjff6.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Delhi Medical Checkup Initiative | Face of Change</title><meta name=\"description\" content=\"Read the full story of our medical camps, health diagnostics, and essential medicine distribution in Delhi NCR&#x27;s underserved slum communities.\"/><meta name=\"keywords\" content=\"NGO India,Face of Change,Rural Education India,Solar Power India,Healthcare Camps Delhi,Odisha Development\"/><meta property=\"og:title\" content=\"Face of Change\"/><meta property=\"og:description\" content=\"Empowering communities through education, healthcare, and renewable energy across India.\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"Face of Change\"/><meta name=\"twitter:description\" content=\"Empowering communities through education, healthcare, and renewable energy across India.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"min-h-full font-sans bg-beige text-navy flex flex-col selection:bg-gold selection:text-navy\"><div hidden=\"\"><!--$--><!--/$--></div><header class=\"fixed top-0 left-0 right-0 z-50 transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] bg-[#FAF9F5]/90 backdrop-blur-md border-b border-navy/5 py-4\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex items-center justify-between\"><a class=\"flex items-center space-x-3 group\" href=\"/\"><div class=\"relative\"><div class=\"w-10 h-10 rounded-full bg-forest flex items-center justify-center text-white border transition-all duration-500 group-hover:rotate-12 group-hover:scale-110 group-hover:shadow-[0_0_20px_rgba(34,197,94,0.4)] border-navy/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-5 h-5 fill-white transition-transform duration-300 group-hover:scale-110\" aria-hidden=\"true\"><path d=\"M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5\"></path></svg></div><div class=\"absolute inset-0 rounded-full bg-forest/30 animate-ping opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none\"></div></div><div class=\"flex flex-col\"><span class=\"font-serif text-lg font-bold tracking-wide transition-all duration-400 group-hover:tracking-wider text-navy group-hover:text-forest\">Face of Change</span></div></a><nav class=\"hidden md:flex items-center space-x-1\"><a class=\"relative px-4 py-2 group\" href=\"/\"><span class=\"text-sm font-medium transition-all duration-300 ease-out relative z-10 text-navy/70 group-hover:text-navy\">Home</span><div class=\"absolute inset-0 rounded-lg bg-navy/[0.04]\" style=\"opacity:0;transform:scale(0.92)\"></div><div class=\"absolute bottom-0 left-1/2 h-[2px] rounded-full bg-gradient-to-r from-forest/0 via-forest to-forest/0\" style=\"width:0%;opacity:0;transform:translateX(-50%)\"></div></a><a class=\"relative px-4 py-2 group\" href=\"/about\"><span class=\"text-sm font-medium transition-all duration-300 ease-out relative z-10 text-navy/70 group-hover:text-navy\">About Us</span><div class=\"absolute inset-0 rounded-lg bg-navy/[0.04]\" style=\"opacity:0;transform:scale(0.92)\"></div><div class=\"absolute bottom-0 left-1/2 h-[2px] rounded-full bg-gradient-to-r from-forest/0 via-forest to-forest/0\" style=\"width:0%;opacity:0;transform:translateX(-50%)\"></div></a><a class=\"relative px-4 py-2 group\" href=\"/projects\"><span class=\"text-sm font-medium transition-all duration-300 ease-out relative z-10 text-navy/70 group-hover:text-navy\">Our Projects</span><div class=\"absolute inset-0 rounded-lg bg-navy/[0.04]\" style=\"opacity:0;transform:scale(0.92)\"></div><div class=\"absolute bottom-0 left-1/2 h-[2px] rounded-full bg-gradient-to-r from-forest/0 via-forest to-forest/0\" style=\"width:0%;opacity:0;transform:translateX(-50%)\"></div></a><a class=\"relative px-4 py-2 group\" href=\"/impact\"><span class=\"text-sm font-medium transition-all duration-300 ease-out relative z-10 text-navy/70 group-hover:text-navy\">Impact</span><div class=\"absolute inset-0 rounded-lg bg-navy/[0.04]\" style=\"opacity:0;transform:scale(0.92)\"></div><div class=\"absolute bottom-0 left-1/2 h-[2px] rounded-full bg-gradient-to-r from-forest/0 via-forest to-forest/0\" style=\"width:0%;opacity:0;transform:translateX(-50%)\"></div></a><a class=\"relative px-4 py-2 group\" href=\"/media\"><span class=\"text-sm font-medium transition-all duration-300 ease-out relative z-10 text-navy/70 group-hover:text-navy\">Media</span><div class=\"absolute inset-0 rounded-lg bg-navy/[0.04]\" style=\"opacity:0;transform:scale(0.92)\"></div><div class=\"absolute bottom-0 left-1/2 h-[2px] rounded-full bg-gradient-to-r from-forest/0 via-forest to-forest/0\" style=\"width:0%;opacity:0;transform:translateX(-50%)\"></div></a><a class=\"relative px-4 py-2 group\" href=\"/contact\"><span class=\"text-sm font-medium transition-all duration-300 ease-out relative z-10 text-navy/70 group-hover:text-navy\">Contact</span><div class=\"absolute inset-0 rounded-lg bg-navy/[0.04]\" style=\"opacity:0;transform:scale(0.92)\"></div><div class=\"absolute bottom-0 left-1/2 h-[2px] rounded-full bg-gradient-to-r from-forest/0 via-forest to-forest/0\" style=\"width:0%;opacity:0;transform:translateX(-50%)\"></div></a></nav><div class=\"flex items-center space-x-4\"><a class=\"hidden lg:flex items-center space-x-2 px-6 py-2.5 rounded-full font-semibold text-sm transition-all duration-400 ease-out hover:scale-105 active:scale-[0.98] group/donate relative overflow-hidden bg-forest text-white hover:shadow-[0_6px_24px_rgba(22,101,52,0.3)]\" href=\"/contact\"><div class=\"absolute inset-0 -translate-x-full group-hover/donate:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/25 to-transparent\"></div><span class=\"relative z-10\">Donate Now</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-4 h-4 relative z-10 transition-transform duration-300 group-hover/donate:scale-125 group-hover/donate:animate-pulse fill-white text-white\" aria-hidden=\"true\"><path d=\"M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5\"></path></svg></a><button class=\"md:hidden p-2 rounded-lg transition-all duration-300 active:scale-90 text-navy hover:bg-navy/5\" aria-label=\"Toggle navigation menu\" id=\"mobile-menu-toggle\"><div><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu w-6 h-6\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></div></button></div></div></div></header><main class=\"flex-grow bg-[#FAF9F5] pt-32 pb-24\"><div class=\"max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12\"><nav class=\"flex items-center space-x-2 text-xs font-semibold uppercase tracking-wider text-navy/40\"><a class=\"hover:text-forest transition-colors\" href=\"/\">Home</a><span>/</span><a class=\"hover:text-forest transition-colors\" href=\"/projects\">Projects</a><span>/</span><span class=\"text-forest\">Delhi Medical Initiative</span></nav><div class=\"space-y-6\"><div class=\"inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-forest/5 border border-forest/15\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-3.5 h-3.5 text-forest fill-forest/15\" aria-hidden=\"true\"><path d=\"M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5\"></path></svg><span class=\"text-[10px] uppercase tracking-widest font-semibold text-forest\">Healthcare Program</span></div><h1 class=\"font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-navy leading-tight max-w-4xl\">Healing Slums: Delivering Diagnostic Care &amp; Medicine Directly to Delhi&#x27;s Marginalized</h1><div class=\"flex flex-wrap gap-4 sm:gap-6 text-xs text-navy/50 font-medium border-y border-navy/5 py-4\"><div class=\"flex items-center space-x-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin w-4 h-4 text-forest\" aria-hidden=\"true\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg><span>Delhi NCR Slums, India</span></div><div class=\"flex items-center space-x-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-calendar w-4 h-4 text-forest\" aria-hidden=\"true\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\"></rect><path d=\"M3 10h18\"></path></svg><span>Launched Jan 2025</span></div><div class=\"flex items-center space-x-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-tag w-4 h-4 text-forest\" aria-hidden=\"true\"><path d=\"M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z\"></path><circle cx=\"7.5\" cy=\"7.5\" r=\".5\" fill=\"currentColor\"></circle></svg><span>Diagnostics, Essential Medicine</span></div></div></div><div class=\"relative aspect-[21/9] w-full rounded-3xl overflow-hidden border border-navy/5 shadow-sm\"><img alt=\"Delhi Medical Camp Cover\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fassets%2Fproject_delhi_medical.png&amp;w=3840&amp;q=75\"/></div><div class=\"text-navy/80 font-sans text-sm sm:text-base leading-relaxed space-y-16\"><div class=\"max-w-3xl space-y-6\"><p class=\"font-medium text-navy text-base sm:text-lg leading-relaxed\">In the heart of Delhi&#x27;s bustling urban sprawl, hundreds of informal settlements (slums) house families living in severe congestion with minimal access to primary healthcare. For a daily wage laborer, missing a day of work to visit a crowded government hospital is an unaffordable luxury. As a result, treatable infections and chronic illnesses go unchecked until they reach critical stages.</p><p>The <strong>Delhi Medical Checkup Initiative</strong> was launched by Face of Change to bridge this gap. Rather than asking patients to travel, we bring the hospital directly to their doorstep. By setting up temporary diagnostic camps in narrow alleys and community centers, we make premium medical consultations and diagnostics completely free and accessible.</p></div><div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center\"><div class=\"lg:col-span-7 space-y-6\"><p>Every diagnostic camp is fully equipped with portable test kits, allowing for rapid testing of blood glucose, hemoglobin, and vital markers. In addition, experienced general physicians, pediatricians, and gynecologists volunteer their time to offer specialized attention to the residents.</p><blockquote class=\"border-l-4 border-forest pl-6 py-2 bg-forest/5 rounded-r-2xl\"><p class=\"font-serif italic text-sm sm:text-base text-navy leading-relaxed\">&quot;Our mission is simple: eliminate the barrier of distance and cost. When healthcare comes to the community, prevention becomes possible.&quot;</p><cite class=\"text-xs font-semibold text-navy/60 not-italic block mt-2\">— Dr. A. Sharma, Program Lead</cite></blockquote></div><div class=\"lg:col-span-5 space-y-2\"><div class=\"relative aspect-[4/3] w-full rounded-2xl overflow-hidden border border-navy/5 shadow-sm\"><img alt=\"Doctor checking child at Delhi camp\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fassets%2Fdelhi_medical_doctor.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fassets%2Fdelhi_medical_doctor.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fassets%2Fdelhi_medical_doctor.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fassets%2Fdelhi_medical_doctor.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fassets%2Fdelhi_medical_doctor.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fassets%2Fdelhi_medical_doctor.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fassets%2Fdelhi_medical_doctor.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fassets%2Fdelhi_medical_doctor.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fassets%2Fdelhi_medical_doctor.png&amp;w=3840&amp;q=75\"/></div><p class=\"text-[11px] text-center text-navy/40 italic\">Volunteer doctor conducting health checkups for children.</p></div></div><div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center\"><div class=\"lg:col-span-5 space-y-2 order-last lg:order-first\"><div class=\"relative aspect-[4/3] w-full rounded-2xl overflow-hidden border border-navy/5 shadow-sm\"><img alt=\"Medicine distribution counter at Delhi camp\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fassets%2Fdelhi_medical_pharmacy.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fassets%2Fdelhi_medical_pharmacy.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fassets%2Fdelhi_medical_pharmacy.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fassets%2Fdelhi_medical_pharmacy.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fassets%2Fdelhi_medical_pharmacy.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fassets%2Fdelhi_medical_pharmacy.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fassets%2Fdelhi_medical_pharmacy.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fassets%2Fdelhi_medical_pharmacy.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fassets%2Fdelhi_medical_pharmacy.png&amp;w=3840&amp;q=75\"/></div><p class=\"text-[11px] text-center text-navy/40 italic\">Our medicine counter offering free prescription drugs.</p></div><div class=\"lg:col-span-7 space-y-6\"><h3 class=\"font-serif text-xl sm:text-2xl font-bold text-navy\">Beyond Diagnostics: Providing the Cure</h3><p>Diagnosing an illness is only the first step. Many families diagnosed with chronic conditions like hypertension or diabetes struggle to afford prescribed treatments. Recognizing this, our camps operate a fully stocked, mobile pharmacy. Patients walk out of their consultation directly to our distribution desk where they receive high-grade, essential medicines, vitamins, and supplements at zero cost.</p><p>Furthermore, we maintain electronic health records of patients with critical readings, ensuring that our team can follow up during subsequent visits. By partnering with local municipal clinics, patients requiring advanced secondary surgery or specialized therapy are smoothly referred and fast-tracked to the correct public care facilities.</p></div></div><div class=\"max-w-3xl space-y-6 pt-4 border-t border-navy/5\"><h3 class=\"font-serif text-xl sm:text-2xl font-bold text-navy\">Measurable Outcomes</h3><p>Since its inception in early 2025, the program has yielded major community impacts:</p><ul class=\"list-disc pl-6 space-y-2.5\"><li>Over <strong>20,000+</strong> individual patient consultations.</li><li>More than <strong>100+</strong> diagnostic camps organized across 50 distinct slum clusters.</li><li>Successful detection and early treatment of anemia in over 2,500 children and pregnant women.</li><li>Regular healthcare monitoring and free drug supplies provided for 800+ diabetic and hypertensive patients.</li></ul></div></div><div class=\"bg-white border border-navy/5 rounded-3xl p-8 sm:p-12 space-y-6 shadow-sm text-center\"><h2 class=\"font-serif text-2xl sm:text-3xl font-bold text-navy\">Help Us Expand Our Medical Reach</h2><p class=\"text-navy/60 text-sm max-w-xl mx-auto leading-relaxed\">Every diagnostic camp costs approximately ₹45,000 ($550) to run, providing complete checkups and medicine to over 200 residents. Partner with us to sponsor a clinic in an underserved area.</p><div class=\"flex flex-col sm:flex-row gap-4 justify-center pt-2\"><a class=\"inline-flex items-center justify-center px-8 py-3.5 rounded-full bg-navy text-white font-semibold text-sm transition-transform duration-300 hover:scale-105 shadow-md\" href=\"/contact\">Sponsor A Health Camp</a><a class=\"inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-navy/20 bg-white text-navy font-semibold text-sm transition-transform duration-300 hover:scale-105 shadow-sm\" href=\"/projects\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-left w-4 h-4 mr-2\" aria-hidden=\"true\"><path d=\"m12 19-7-7 7-7\"></path><path d=\"M19 12H5\"></path></svg>Back to Projects</a></div></div></div></main><footer class=\"bg-navy text-white pt-16 pb-8 border-t border-white/5\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16\"><div class=\"lg:col-span-2 flex flex-col space-y-6\"><a class=\"flex items-center space-x-2.5\" href=\"/\"><div class=\"w-10 h-10 rounded-full bg-forest flex items-center justify-center text-white border border-white/20\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-5 h-5 fill-white\" aria-hidden=\"true\"><path d=\"M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5\"></path></svg></div><div class=\"flex flex-col\"><span class=\"font-serif text-lg font-bold tracking-wide text-white\">Face of Change</span></div></a><p class=\"text-white/60 text-sm leading-relaxed max-w-sm\">Working towards a better India through education, healthcare, clean energy, and community development. Together, we build sustainable and equitable futures.</p><div class=\"flex space-x-4\"><a href=\"https://facebook.com\" id=\"footer-fb\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/80 hover:bg-forest hover:text-white transition-all duration-300\"><svg viewBox=\"0 0 24 24\" width=\"16\" height=\"16\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-4 h-4\"><path d=\"M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z\"></path></svg></a><a href=\"https://instagram.com\" id=\"footer-ig\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/80 hover:bg-forest hover:text-white transition-all duration-300\"><svg viewBox=\"0 0 24 24\" width=\"16\" height=\"16\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-4 h-4\"><rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"5\" ry=\"5\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\"></path><line x1=\"17.5\" y1=\"6.5\" x2=\"17.51\" y2=\"6.5\"></line></svg></a><a href=\"https://twitter.com\" id=\"footer-tw\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/80 hover:bg-forest hover:text-white transition-all duration-300\"><svg 