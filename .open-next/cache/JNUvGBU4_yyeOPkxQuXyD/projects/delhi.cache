e\\\":[[\\\"path\\\",{\\\"d\\\":\\\"M8 2v4\\\",\\\"key\\\":\\\"1cmpym\\\"}],[\\\"path\\\",{\\\"d\\\":\\\"M16 2v4\\\",\\\"key\\\":\\\"4m81vk\\\"}],[\\\"rect\\\",{\\\"width\\\":\\\"18\\\",\\\"height\\\":\\\"18\\\",\\\"x\\\":\\\"3\\\",\\\"y\\\":\\\"4\\\",\\\"rx\\\":\\\"2\\\",\\\"key\\\":\\\"1hopcy\\\"}],[\\\"path\\\",{\\\"d\\\":\\\"M3 10h18\\\",\\\"key\\\":\\\"8toen8\\\"}]],\\\"className\\\":\\\"lucide-calendar w-4 h-4 text-forest\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"Launched Jan 2025\\\"}]]}]\\na:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center space-x-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L6\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"iconNode\\\":[[\\\"path\\\",{\\\"d\\\":\\\"M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z\\\",\\\"key\\\":\\\"vktsd0\\\"}],[\\\"circle\\\",{\\\"cx\\\":\\\"7.5\\\",\\\"cy\\\":\\\"7.5\\\",\\\"r\\\":\\\".5\\\",\\\"fill\\\":\\\"currentColor\\\",\\\"key\\\":\\\"kqv944\\\"}]],\\\"className\\\":\\\"lucide-tag w-4 h-4 text-forest\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"Diagnostics, Essential Medicine\\\"}]]}]\\nb:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative aspect-[21/9] w-full rounded-3xl overflow-hidden border border-navy/5 shadow-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"$L16\\\",null,{\\\"src\\\":\\\"/assets/project_delhi_medical.png\\\",\\\"alt\\\":\\\"Delhi Medical Camp Cover\\\",\\\"fill\\\":true,\\\"priority\\\":true,\\\"className\\\":\\\"object-cover\\\"}]}]\\n\"])</script><script>self.__next_f.push([1,\"c:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-navy/80 font-sans text-sm sm:text-base leading-relaxed space-y-16\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-3xl space-y-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"font-medium text-navy text-base sm:text-lg leading-relaxed\\\",\\\"children\\\":\\\"In the heart of Delhi's bustling urban sprawl, hundreds of informal settlements (slums) house families living in severe congestion with minimal access to primary healthcare. For a daily wage laborer, missing a day of work to visit a crowded government hospital is an unaffordable luxury. As a result, treatable infections and chronic illnesses go unchecked until they reach critical stages.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"The \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Delhi Medical Checkup Initiative\\\"}],\\\" was launched by Face of Change to bridge this gap. Rather than asking patients to travel, we bring the hospital directly to their doorstep. By setting up temporary diagnostic camps in narrow alleys and community centers, we make premium medical consultations and diagnostics completely free and accessible.\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"lg:col-span-7 space-y-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Every diagnostic camp is fully equipped with portable test kits, allowing for rapid testing of blood glucose, hemoglobin, and vital markers. In addition, experienced general physicians, pediatricians, and gynecologists volunteer their time to offer specialized attention to the residents.\\\"}],[\\\"$\\\",\\\"blockquote\\\",null,{\\\"className\\\":\\\"border-l-4 border-forest pl-6 py-2 bg-forest/5 rounded-r-2xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"font-serif italic text-sm sm:text-base text-navy leading-relaxed\\\",\\\"children\\\":\\\"\\\\\\\"Our mission is simple: eliminate the barrier of distance and cost. When healthcare comes to the community, prevention becomes possible.\\\\\\\"\\\"}],[\\\"$\\\",\\\"cite\\\",null,{\\\"className\\\":\\\"text-xs font-semibold text-navy/60 not-italic block mt-2\\\",\\\"children\\\":\\\"— Dr. A. Sharma, Program Lead\\\"}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"lg:col-span-5 space-y-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative aspect-[4/3] w-full rounded-2xl overflow-hidden border border-navy/5 shadow-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"$L16\\\",null,{\\\"src\\\":\\\"/assets/delhi_medical_doctor.png\\\",\\\"alt\\\":\\\"Doctor checking child at Delhi camp\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover\\\"}]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-[11px] text-center text-navy/40 italic\\\",\\\"children\\\":\\\"Volunteer doctor conducting health checkups for children.\\\"}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"lg:col-span-5 space-y-2 order-last lg:order-first\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative aspect-[4/3] w-full rounded-2xl overflow-hidden border border-navy/5 shadow-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"$L16\\\",null,{\\\"src\\\":\\\"/assets/delhi_medical_pharmacy.png\\\",\\\"alt\\\":\\\"Medicine distribution counter at Delhi camp\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover\\\"}]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-[11px] text-center text-navy/40 italic\\\",\\\"children\\\":\\\"Our medicine counter offering free prescription drugs.\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"lg:col-span-7 space-y-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-serif text-xl sm:text-2xl font-bold text-navy\\\",\\\"children\\\":\\\"Beyond Diagnostics: Providing the Cure\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Diagnosing an illness is only the first step. Many families diagnosed with chronic conditions like hypertension or diabetes struggle to afford prescribed treatments. Recognizing this, our camps operate a fully stocked, mobile pharmacy. Patients walk out of their consultation directly to our distribution desk where they receive high-grade, essential medicines, vitamins, and supplements at zero cost.\\\"}],\\\"$L17\\\"]}]]}],\\\"$L18\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"d:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"bg-white border border-navy/5 rounded-3xl p-8 sm:p-12 space-y-6 shadow-sm text-center\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"font-serif text-2xl sm:text-3xl font-bold text-navy\\\",\\\"children\\\":\\\"Help Us Expand Our Medical Reach\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-navy/60 text-sm max-w-xl mx-auto leading-relaxed\\\",\\\"children\\\":\\\"Every diagnostic camp costs approximately ₹45,000 ($550) to run, providing complete checkups and medicine to over 200 residents. Partner with us to sponsor a clinic in an underserved area.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-col sm:flex-row gap-4 justify-center pt-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L5\\\",null,{\\\"href\\\":\\\"/contact\\\",\\\"className\\\":\\\"inline-flex items-center justify-center px-8 py-3.5 rounded-full bg-navy text-white font-semibold text-sm transition-transform duration-300 hover:scale-105 shadow-md\\\",\\\"children\\\":\\\"Sponsor A Health Camp\\\"}],[\\\"$\\\",\\\"$L5\\\",null,{\\\"href\\\":\\\"/projects\\\",\\\"className\\\":\\\"inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-navy/20 bg-white text-navy font-semibold text-sm transition-transform duration-300 hover:scale-105 shadow-sm\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L6\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"iconNode\\\":[[\\\"path\\\",{\\\"d\\\":\\\"m12 19-7-7 7-7\\\",\\\"key\\\":\\\"1l729n\\\"}],[\\\"path\\\",{\\\"d\\\":\\\"M19 12H5\\\",\\\"key\\\":\\\"x3x0zl\\\"}]],\\\"className\\\":\\\"lucide-arrow-left w-4 h-4 mr-2\\\"}],\\\"Back to Projects\\\