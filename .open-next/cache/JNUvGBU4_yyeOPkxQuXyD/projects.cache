051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z\"></path><path d=\"M20 2v4\"></path><path d=\"M22 4h-4\"></path><circle cx=\"4\" cy=\"20\" r=\"2\"></circle></svg><span class=\"text-[10px] uppercase tracking-widest font-semibold text-forest\">Ground Level Interventions</span></div><h1 class=\"font-serif text-4xl sm:text-5xl md:text-6xl font-bold leading-none tracking-wide text-navy\">Our <span class=\"text-forest\">Projects</span></h1><p class=\"text-navy/60 text-sm sm:text-base max-w-2xl leading-relaxed font-sans\">Discover the projects we run to build sustainable ecosystems, power villages, transform classrooms, and deliver healthcare.</p></div></div><section id=\"projects\" class=\"bg-beige/40 py-24 md:py-32\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex flex-col md:flex-row md:items-end justify-between mb-16\"><div class=\"space-y-4 max-w-2xl\"><span class=\"text-xs font-semibold tracking-widest text-forest uppercase block\">Our Initiatives</span><h2 class=\"font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-navy leading-tight\">Featured Projects Making Real Difference.</h2></div><p class=\"text-navy/60 text-sm sm:text-base max-w-xs mt-4 md:mt-0 leading-relaxed\">Focused on building clean energy foundations and providing critical healthcare checkups directly where resources are scarce.</p></div><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12\"><div id=\"project-odisha\" class=\"bg-white rounded-3xl overflow-hidden border border-navy/5 shadow-[0_15px_40px_rgba(15,23,42,0.02)] hover:shadow-[0_30px_70px_rgba(15,23,42,0.06)] transition-all duration-500 flex flex-col justify-between group\" style=\"opacity:0;transform:translateY(40px)\"><div><div class=\"relative aspect-[16/10] overflow-hidden w-full\"><img alt=\"Odisha Solar Plant Project\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-700 group-hover:scale-105\" style=\