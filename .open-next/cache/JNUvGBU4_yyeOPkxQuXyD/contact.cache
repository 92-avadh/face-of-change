y:0;transform:scale(0.92)\"></div><div class=\"absolute bottom-0 left-1/2 h-[2px] rounded-full bg-gradient-to-r from-forest/0 via-forest to-forest/0\" style=\"width:0%;opacity:0;transform:translateX(-50%)\"></div></a><a class=\"relative px-4 py-2 group\" href=\"/media\"><span class=\"text-sm font-medium transition-all duration-300 ease-out relative z-10 text-navy/70 group-hover:text-navy\">Media</span><div class=\"absolute inset-0 rounded-lg bg-navy/[0.04]\" style=\"opacity:0;transform:scale(0.92)\"></div><div class=\"absolute bottom-0 left-1/2 h-[2px] rounded-full bg-gradient-to-r from-forest/0 via-forest to-forest/0\" style=\"width:0%;opacity:0;transform:translateX(-50%)\"></div></a><a class=\"relative px-4 py-2 group\" href=\"/contact\"><span class=\"text-sm font-medium transition-all duration-300 ease-out relative z-10 text-forest\">Contact</span><div class=\"absolute inset-0 rounded-lg bg-navy/[0.04]\" style=\"opacity:0;transform:scale(0.92)\"></div><div class=\"absolute bottom-0 left-1/2 h-[2px] rounded-full bg-gradient-to-r from-forest/0 via-forest to-forest/0\" style=\"width:70%;opacity:1;transform:translateX(-50%)\"></div><div class=\"absolute -bottom-1.5 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-forest\"></div></a></nav><div class=\"flex items-center space-x-4\"><a class=\"hidden lg:flex items-center space-x-2 px-6 py-2.5 rounded-full font-semibold text-sm transition-all duration-400 ease-out hover:scale-105 active:scale-[0.98] group/donate relative overflow-hidden bg-forest text-white hover:shadow-[0_6px_24px_rgba(22,101,52,0.3)]\" href=\"/contact\"><div class=\"absolute inset-0 -translate-x-full group-hover/donate:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/25 to-transparent\"></div><span class=\"relative z-10\">Donate Now</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-4 h-4 relative z-10 transition-transform duration-300 group-hover/donate:scale-125 group-hover/donate:animate-pulse fill-white text-white\" aria-hidden=\"true\"><path d=\"M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5\"></path></svg></a><button class=\"md:hidden p-2 rounded-lg transition-all duration-300 active:scale-90 text-navy hover:bg-navy/5\" aria-label=\"Toggle navigation menu\" id=\"mobile-menu-toggle\"><div><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu w-6 h-6\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></div></button></div></div></div></header><main class=\"flex-grow bg-beige/25\"><div class=\"bg-[#FAF9F5] text-navy pt-36 pb-20 relative overflow-hidden border-b border-navy/5\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20 space-y-4\"><nav class=\"flex space-x-2 text-xs font-semibold uppercase tracking-wider text-navy/40\"><a class=\"hover:text-forest transition-colors\" href=\"/\">Home</a><span>/</span><span class=\"text-navy\">Contact &amp; Partner</span></nav><div class=\"inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-forest/5 border border-forest/15 backdrop-blur-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sparkles w-3.5 h-3.5 text-forest\" aria-hidden=\"true\"><path d=\"M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z\"></path><path d=\"M20 2v4\"></path><path d=\"M22 4h-4\"></path><circle cx=\"4\" cy=\"20\" r=\"2\"></circle></svg><span class=\"text-[10px] uppercase tracking-widest font-semibold text-forest\">Get In Touch</span></div><h1 class=\"font-serif text-4xl sm:text-5xl md:text-6xl font-bold leading-none tracking-wide text-navy\">Contact <span class=\"text-forest\">Us</span></h1><p class=\"text-navy/60 text-sm sm:text-base max-w-2xl leading-relaxed font-sans\">Have questions about sponsorships, CSR integrations, or project areas? Connect with our team today.</p></div></div><section id=\"contact\" class=\"bg-beige/20 py-24 md:py-32 border-b border-navy/5\"><div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"bg-white rounded-3xl border border-navy/5 p-8 sm:p-10 shadow-[0_15px_40px_rgba(15,23,42,0.02)]\"><div class=\"flex items-center space-x-3 mb-6\"><div class=\"w-10 h-10 rounded-xl bg-gold/10 text-gold flex items-center justify-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-message-square w-5 h-5 text-amber-600\" aria-hidden=\"true\"><path d=\"M22 17a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 21.286V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z\"></path></svg></div><div><span class=\"text-[10px] uppercase font-bold tracking-widest text-amber-600 block\">Support Our Projects</span><h3 class=\"font-serif font-bold text-2xl text-navy\">General Inquiry &amp; CSR Partnerships</h3></div></div><p class=\"text-navy/60 text-xs sm:text-sm leading-relaxed mb-8\">Discuss corporate partnerships, classroom sponsorships, solar initiatives, or write general inquiries. Our partnership desk responds within 2 business days.</p><form class=\"space-y-4\" id=\"contact-form\"><div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4\"><div><label for=\"contact-name\" class=\"text-xs font-semibold text-navy/60 uppercase tracking-wider block mb-1\">Contact Name *</label><input type=\"text\" id=\"contact-name\" required=\"\" placeholder=\"Name\" class=\"w-full bg-beige/30 border border-navy/5 rounded-xl py-3 px-4 text-sm text-navy placeholder-navy/30 focus:outline-none focus:border-forest focus:ring-1 focus:ring-forest transition-colors\" value=\"\"/></div><div><label for=\"contact-org\" class=\"text-xs font-semibold text-navy/60 uppercase tracking-wider block mb-1\">Organization / Company</label><input type=\"text\" id=\"contact-org\" placeholder=\"Company Name\" class=\"w-full bg-beige/30 border border-navy/5 rounded-xl py-3 px-4 text-sm text-navy placeholder-navy/30 focus:outline-none focus:border-forest focus:ring-1 focus:ring-forest transition-colors\" value=\"\"/></div></div><div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4\"><div><label for=\"contact-email\" class=\"text-xs font-semibold text-navy/60 uppercase tracking-wider block mb-1\">Email Address *</label><input type=\"email\" id=\"contact-email\" required=\"\" placeholder=\"name@email.com\" class=\"w-full bg-beige/30 border border-navy/5 rounded-xl py-3 px-4 text-sm text-navy placeholder-navy/30 focus:outline-none focus:border-forest focus:ring-1 focus:ring-forest transition-colors\" value=\"\"/></div><div><label for=\"contact-phone\" class=\"text-xs font-semibold text-navy/60 uppercase tracking-wider block mb-1\">Phone (Optional)</label><input type=\"tel\" id=\"contact-phone\" placeholder=\"+91 XXXXX XXXXX\" class=\"w-full bg-beige/30 border border-navy/5 rounded-xl py-3 px-4 text-sm text-navy placeholder-navy/30 focus:outline-none focus:border-forest focus:ring-1 focus:ring-forest transition-colors\" value=\"\"/></div></div><div><label for=\"contact-area\" class=\"text-xs font-semibold text-navy/60 uppercase tracking-wider block mb-1\">Area of Interest *</label><select id=\"contact-area\" class=\"w-full bg-beige/35 border border-navy/5 rounded-xl py-3 px-4 text-sm text-navy focus:outline-none focus:border-forest focus:ring-1 focus:ring-forest transition-colors\"><option value=\"Education\" selected=\"\">Classroom Sponsor &amp; Education</option><option value=\"Healthcare\">Healthcare Support &amp; Diagnostics</option><option value=\"Renewable Energy\">Renewable Solar Grids</option><option value=\"General\">General Inquiry &amp; Donations</option></select></div><div><label for=\"contact-message\" class=\"text-xs font-semibold text-navy/60 uppercase tracking-wider block mb-1\">Message / Details *</label><textarea id=\"contact-message\" rows=\"4\" required=\"\" placeholder=\"Tell us details about your CSR requirements or donation inquiry...\" class=\"w-full bg-beige/30 border border-navy/5 rounded-xl py-3 px-4 text-sm text-navy placeholder-navy/30 focus:outline-none focus:border-forest focus:ring-1 focus:ring-forest transition-colors resize-none\"></textarea></div><button type=\"submit\" class=\"w-full py-3 rounded-full bg-gold text-navy font-semibold text-sm transition-colors duration-300 hover:bg-gold/90 flex items-center justify-center space-x-2 disabled:opacity-50 shadow-md\" id=\"contact-submit-btn\"><span>Send Inquiry Message</span></button></form></div></div></section><section id=\"partnership\" class=\"bg-[#FAF9F5] text-navy py-20 border-b border-navy/5\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\"><div class=\"lg:col-span-5 space-y-6\"><span class=\"text-xs font-semibold tracking-widest text-forest uppercase block\">Be The Change</span><h2 class=\"font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-navy leading-tight\">Partner With Us To Build A Better Tomorrow.</h2><p class=\"text-navy/60 text-sm sm:text-base leading-relaxed\">We collaborate with corporates, CSR foundations, and global donors to execute certified, high-impact projects. Align your corporate social responsibility goals with our measurable local initiatives.</p><div class=\"pt-4\"><a href=\"#contact\" class=\"inline-flex items-center justify-between px-6 py-3.5 rounded-full bg-forest text-white font-semibold text-sm transition-all duration-300 hover:scale-105 shadow-[0_4px_14px_rgba(22,101,52,0.2)]\"><span>Become a Partner</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-4 h-4 ml-3 text-white\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div></div><div class=\"lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6\"><div class=\"bg-white border border-navy/5 rounded-2xl p-6 hover:border-forest/20 shadow-sm transition-all\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex items-center space-x-4 mb-4\"><div class=\"w-10 h-10 rounded-xl bg-forest/10 text-forest flex items-center justify-center border border-forest/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-graduation-cap w-5 h-5\" aria-hidden=\"true\"><path d=\"M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z\"></path><path d=\"M22 10v6\"></path><path d=\"M6 12.5V16a6 3 0 0 0 12 0v-3.5\"></path></svg></div><h3 class=\"font-serif font-bold text-base text-navy\">Sponsor A Classroom</h3></div><p class=\"text-navy/60 text-xs leading-relaxed\">Provide modern desks, learning materials, and infrastructural upgrades for a village school.</p></div><div class=\"bg-white border border-navy/5 rounded-2xl p-6 hover:border-forest/20 shadow-sm transition-all\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex items-center space-x-4 mb-4\"><div class=\"w-10 h-10 rounded-xl bg-forest/10 text-forest flex items-center justify-center border border-forest/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart-handshake w-5 h-5\" aria-hidden=\"true\"><path d=\"M19.414 14.414C21 12.828 22 11.5 22 9.5a5.5 5.5 0 0 0-9.591-3.676.6.6 0 0 1-.818.001A5.5 5.5 0 0 0 2 9.5c0 2.3 1.5 4 3 5.5l5.535 5.362a2 2 0 0 0 2.879.052 2.12 2.12 0 0 0-.004-3 2.124 2.124 0 1 0 3-3 2.124 2.124 0 0 0 3.004 0 2 2 0 0 0 0-2.828l-1.881-1.882a2.41 2.41 0 0 0-3.409 0l-1.71 1.71a2 2 0 0 1-2.828 0 2 2 0 0 1 0-2.828l2.823-2.762\"></path></svg></div><h3 class=\"font-serif font-bold text-base text-navy\">Support Child&#x27;s Education</h3></div><p class=\"text-navy/60 text-xs leading-relaxed\">Fund learning kits, textbooks, and tutoring support to keep vulnerable students in school.</p></div><div class=\"bg-white border border-navy/5 rounded-2xl p-6 hover:border-forest/20 shadow-sm transition-all\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex items-center space-x-4 mb-4\"><div class=\"w-10 h-10 rounded-xl bg-forest/10 text-forest flex items-center justify-center border border-forest/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-alert w-5 h-5\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"M12 8v4\"></path><path d=\"M12 16h.01\"></path></svg></div><h3 class=\"font-serif font-bold text-base text-navy\">Healthcare Support</h3></div><p class=\"text-navy/60 text-xs leading-relaxed\">Sponsor diagnostic kits, doctors, and medical camps in low-income community clusters.</p></div><div class=\"bg-white border border-navy/5 rounded-2xl p-6 hover:border-forest/20 shadow-sm transition-all\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex items-center space-x-4 mb-4\"><div class=\"w-10 h-10 rounded-xl bg-forest/10 text-forest flex items-center justify-center border border-forest/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sun-dim w-5 h-5\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 4h.01\"></path><path d=\"M20 12h.01\"></path><path d=\"M12 20h.01\"></path><path d=\"M4 12h.01\"></path><path d=\"M17.657 6.343h.01\"></path><path d=\"M17.657 17.657h.01\"></path><path d=\"M6.343 17.657h.01\"></path><path d=\"M6.343 6.343h.01\"></path></svg></div><h3 class=\"font-serif font-bold text-base text-navy\">Renewable Energy Projects</h3></div><p class=\"text-navy/60 text-xs leading-relaxed\">Partner to install high-efficiency solar microgrids and power clean community water projects.</p></div></div></div></div></section></main><footer class=\"bg-navy text-white pt-16 pb-8 border-t border-white/5\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16\"><div class=\"lg:col-span-2 flex flex-col space-y-6\"><a class=\"flex items-center space-x-2.5\" href=\"/\"><div class=\"w-10 h-10 rounded-full bg-forest flex items-center justify-center text-white border border-white/20\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-5 h-5 fill-white\" aria-hidden=\"true\"><path d=\"M2 9.5a5.5 5.5 0 0 1 9.591-3.676